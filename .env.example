# SOC Sentinel server configuration
FLASK_CONFIG=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///soc_server/database/soc_sentinel.db
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
PUBLIC_URL=https://your-server.example.com
LOG_LEVEL=INFO

# Optional correlation settings
ENDPOINT_HEARTBEAT_TIMEOUT_SECONDS=90
CORRELATION_RETENTION_SECONDS=900
CORRELATION_DUPLICATE_COOLDOWN_SECONDS=300
