# SOC Sentinel production environment
SOC_SENTINEL_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:////opt/soc-sentinel/SOC-Sentinel/soc_server/database/soc_sentinel.db
HOST=127.0.0.1
PORT=5000
LOG_LEVEL=INFO
SERVER_URL=https://your-domain.example.com
SESSION_TIMEOUT=3600

# Optional compatibility aliases
FLASK_CONFIG=production
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
PUBLIC_URL=https://your-domain.example.com

# Logging
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# Optional SOC Sentinel tuning
ENDPOINT_HEARTBEAT_TIMEOUT_SECONDS=90
CORRELATION_RETENTION_SECONDS=900
CORRELATION_DUPLICATE_COOLDOWN_SECONDS=300
